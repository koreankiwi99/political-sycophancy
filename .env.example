# Copy to `.env` (repo root) OR `~/red_teaming/.env`, then fill in your key.
# The pipeline scripts resolve the key in this order:
#   1. $OPENROUTER_API_KEY environment variable
#   2. <repo-root>/.env
#   3. ~/red_teaming/.env
# `.env` is gitignored — never commit a real key.

OPENROUTER_API_KEY=sk-or-v1-...
